{
    //PLUS
    println(3 + 4);
    println(3.3 + 4);
    println(4 + 3.3);
    println(3.3 + 3.3);
    println();

    //MINUS
    println(3 - 4);
    println(3.3 - 4);
    println(4 - 3.3);
    println(3.3 - 3.3);
    println();

    //MULT
    println(3 * 4);
    println(3.3 * 4);
    println(4 * 3.3);
    println(3.3 * 3.3);
    println();

    //DIVIDE
    println(8 / 4);
    println(3.3 / 4);
    println(4 / 3.2);
    println(3.3 / 3.3);

}