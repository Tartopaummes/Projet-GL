{
    //EQ
    println("EQ");
    if (3 == 4){
        println("KO");
    }else{
        println("OK");
    }

    if (3.3 == 6){
        println("KO");
    }else{
        println("OK");
    }

    if (6 == 3.3){
        println("KO");
    }else{
        println("OK");
    }

    if (4.4 == 4.4){
        println("OK");
    }else{
        println("KO");
    }

    //NEQ
    println("NEQ");
    if (3 != 4){
        println("OK");
    }else{
        println("KO");
    }

    if (3 != 4){
        println("OK");
    }else{
        println("KO");
    }

    if (6 != 3.3){
        println("OK");
    }else{
        println("KO");
    }

    if (4.4 != 4.4){
        println("KO");
    }else{
        println("OK");
    }

    //LT
    println("LT");

    if (3 < 4){
        println("OK");
    }else{
        println("KO");
    }

    if (3.3 < 6){
        println("OK");
    }else{
        println("KO");
    }

    if (6 < 3.3){
        println("KO");
    }else{
        println("OK");
    }

    if (4.4 < 4.4){
        println("KO");
    }else{
        println("OK");
    }


    //GT
    println("GT");

    if (3 > 4){
        println("KO");
    }else{
        println("OK");
    }

    if (3.3 > 6){
        println("KO");
    }else{
        println("OK");
    }

    if (6 > 3.3){
        println("OK");
    }else{
        println("KO");
    }

    if (4.4 > 4.4){
        println("KO");
    }else{
        println("OK");
    }

    //LEQ
    println("LEQ");

    if (3 <= 4){
        println("OK");
    }else{
        println("KO");
    }

    if (3.3 <= 6){
        println("OK");
    }else{
        println("KO");
    }

    if (6 <= 3.3){
        println("KO");
    }else{
        println("OK");
    }

    if (4.4 <= 4.4){
        println("OK");
    }else{
        println("KO");
    }


    //GEQ
    println("GEQ");

    if (3 >= 4){
        println("KO");
    }else{
        println("OK");
    }

    if (3.3 >= 6){
        println("KO");
    }else{
        println("OK");
    }

    if (6 >= 3.3){
        println("OK");
    }else{
        println("KO");
    }

    if (4.4 >= 4.4){
        println("OK");
    }else{
        println("OK");
    }

}