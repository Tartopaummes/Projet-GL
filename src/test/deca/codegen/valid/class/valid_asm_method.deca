        asm("TSTO #0 \\n BOV stackOverflow \\n PUSH R2 \\n LOAD -2(LB), R2 \\n LOAD #1, R0 \\n BRA end.Dummy.ret1 \\n BRA no_return_in_non_void_error \\n end.Dummy.ret1: \\n POP R2 \\n RTS");//method who return 1
