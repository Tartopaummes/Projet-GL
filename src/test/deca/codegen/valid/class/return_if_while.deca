class Test {
    int whileMethod(){
        int i=5;
        while (i >0){
            i = i - 1;
            return 15;
        }
    }
    int ifMethod(){
        if(true){
            if(true){
                if(false){
                    return 2;
                }else{
                    return 15;
                }
            }
        }
    }
}

{
    Test t = new Test();
    println(t.ifMethod());
    println(t.whileMethod());
}
