class A {
     int a = 1;

     B myMethod() {
         return new B();
     }
}

class B {
    int a = 1;

    void setA(int a) {
        this.a = a;
    }
}

{
    A a = new A();
    B b = a.myMethod();
    b.setA(2);
    println(a.a);
    println(b.a);
}