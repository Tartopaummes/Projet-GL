class Test {
    int a = 2;
    float b = 3.0;
}

{
    Test testObj = new Test();
    println("a = ", testObj.a);
    printlnx("a = ", testObj.a);
    println("b = ", testObj.b);
    printlnx("b = ", testObj.b);
}