// Description:
//    Test simple with a class with many fields with initialization and print them
// Resultat:
//[Begin Result]
//0
//42
//0.00000e+00
//4.24200e+01
//0
//1
//[End Result]
//
// History:
//    créé le 14/01/2025

class Test {
    int a;
    int b = 42;
    float c;
    float d = 42.42;
    boolean e;
    boolean f = true;
}

{
    Test t = new Test();
    println(t.a);
    println(t.b);
    println(t.c);
    println(t.d);
    if (t.e) {
        println(1);
    } else {
        println(0);
    }
    if (t.f) {
        println(1);
    } else {
        println(0);
    }
}
