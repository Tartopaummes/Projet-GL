// Description:
//    Test simple if and if else statements
// Resultat:
//[Begin Result]
//1
//True
//2
//False
//3
//True
//4
//[End Result]
//
// History:
//    créé le 08/01/2025

{

    println("1");
    if (true) {
        println("True");
    }else{
        println("False");
    }
    println("2");
    if (false) {
        println("True");
    }else{
        println("False");
    }
    println("3");
    if (true) {
        println("True");
    }
    println("4");
    if (false) {
        println("True");
    }

}