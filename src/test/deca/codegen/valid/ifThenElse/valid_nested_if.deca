{

    boolean a = true;
    boolean b = false;
    boolean c = true;
    boolean d = false;
    if(a){
        if (b) {
            println("1");
        }else if (c){
            println("2");
        }else{
            println("3");
        }
    }else{
        print("4");
    }

    if(a){
        if (b) {
            println("5");
        }else if (d){
            println("6");
        }else{
            println("7");
        }
    }else{
        print("8");
    }

}