{
        println("Hello Agent 47.");
        println("Your mission is to skip a line.");
        println("You shouldn't skip lines.");
        println("There is a quote : \" here.");
        println("There is a backslash : \\ here.");
        println("There is two backslash : \\\\ here.");
}