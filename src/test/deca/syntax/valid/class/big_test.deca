class Object { }

class Thing extends Object {
    int a, b, c, d;
    protected String e, f, g;
    boolean h, i, j;
}

class test extends Thing {
    void test() {
        int a = 10;
        int b = new Object();
        a.this_is_a_test = 1;
        a.this_is_a_test(b, c);
        a.this_is_a_test = a.this_is_a_test(b, c);
        a.this_is_a_test(b, c).this_is_a_test = 1;
    }

    Object test2(int first, float second, boolean third) {
        this.a = first;
        this.e = second;
        this.h = third;
        b = first;
        f = second;
        i = third;
        return new Object();
    }

    boolean test3(Object a, Thing b) {
        a.this_is_a_test = 1;
        b.test2(1, 2.0, true);
        if (a instanceof Thing) {
