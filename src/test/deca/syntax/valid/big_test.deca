{
    int value = 10;
    if (value > 0) {
        if (value % 2 == 0) {
            print("Value is positive and even.");
        } else {
            print("Value is positive and odd.");
        }
    } else if (value < 0) {
        if (value % 2 == 0) {
            print("Value is negative and even.");
        } else {
            print("Value is negative and odd.");
        }
    } else {
        print("Value is zero.");
    }

    // Additional test with more complex conditions
    if (25 < 18) {
        print("Minor");
    } else if (25 >= 18 && 25 <= 65) {
        if (25 >= 18 && 25 < 30) {
            print("Young adult");
        } else {
            print("Adult");
        }
    } else {
        print("Senior citizen");
    }
}