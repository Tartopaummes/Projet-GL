{
    int a = 10;
    float b = 10.0;
    boolean c = true;
    String d = "Hello";

    if (a instanceof int) {
        print("a is an int");
    }
    if (b instanceof float) {
        print("b is a float");
    }
    if (c instanceof boolean) {
        print("c is a boolean");
    }
    if (d instanceof String) {
        print("d is a String");
    }
}