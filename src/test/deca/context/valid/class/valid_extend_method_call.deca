class Dummy {
    int a = 5;
    void add(int a, int b, int c) {
        this.a = a + b + c;
        println(this.a);
    }
}

class Dummy2 extends Dummy {

}

{
    Dummy2 d = new Dummy2();
    d.add(1, 2, 3);
}
