class MySuperClass{
}

class MyClass extends MySuperClass{
}

class SuperDummy{
    MySuperClass myMethod(){
        return new MySuperClass();
    }
}

class Dummy extends SuperDummy{
    MyClass myMethod(){
        return new MyClass();
    }
}

{
